---
/**
 * Override for Starlight's `Search` component slot. We render the
 * default Search bar verbatim and inline the agency-size dropdown next
 * to it so the picker is visible on every page.
 */
import Default from '@astrojs/starlight/components/Search.astro';
import AgencyPathDropdown from './AgencyPathDropdown.astro';
---

<div class="aqg-header-extras">
  <AgencyPathDropdown />
  <Default {...Astro.props}><slot /></Default>
</div>

<script>
  function labelThemeSelects() {
    const selects = [...document.querySelectorAll('select')].filter((select) =>
      select.closest('label')?.textContent?.includes('Select theme')
    );
    selects.forEach((select, index) => {
      if (!select.id) select.id = `aqg-theme-select-${index + 1}`;
      if (!select.getAttribute('name')) {
        select.setAttribute('name', `aqg-theme-select-${index + 1}`);
      }
    });
  }

  labelThemeSelects();
  document.addEventListener('astro:after-swap', labelThemeSelects);
</script>
