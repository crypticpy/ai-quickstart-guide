{
  "name": "ai-quickstart-guide",
  "type": "module",
  "version": "0.1.0",
  "description": "AI Quickstart Strategy Guide — a 12-month playbook for government agencies adopting AI",
  "private": false,
  "license": "SEE LICENSE (MIT for code, CC-BY-SA-4.0 for content)",
  "homepage": "https://crypticpy.github.io/ai-quickstart-guide/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crypticpy/ai-quickstart-guide.git"
  },
  "bugs": {
    "url": "https://github.com/crypticpy/ai-quickstart-guide/issues"
  },
  "keywords": [
    "ai",
    "government",
    "public-sector",
    "playbook",
    "astro",
    "starlight"
  ],
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "tsc --noEmit --strict --skipLibCheck --jsx react-jsx --jsxImportSource preact --moduleResolution bundler --module ESNext --target ES2022 --allowImportingTsExtensions src/components/*.tsx src/lib/*.ts",
    "lint:links": "node scripts/check-links.mjs",
    "export:playbook": "node scripts/build-playbook.mjs",
    "check:export": "node scripts/check-export.mjs",
    "check:deck-sources": "node scripts/check-deck-sources.mjs"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@astrojs/preact": "^5.0.0",
    "@astrojs/starlight": "^0.38.0",
    "astro": "^6.1.0",
    "preact": "^10.25.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^6.0.3"
  }
}
